<pre>$LBPeriod=3D200;

$Period=3D40;

$Pds=3D3;

Dist1 =3D ABS(CLOSE()-CLOSE(OFFSET=3D$Period));

D1=3D(Dist1-LOWESTLOW(Dist1, BARS=3D$LBPeriod)) / (HIGHESTHIGH(Dist1, BARS=
=3D$LBPeriod) - LOWESTLOW(Dist1, BARS=3D$LBPeriod));

DD1=3DIF(CLOSE()&gt;CLOSE(OFFSET=3D$Period),D1, IF(CLOSE()&lt;CLOSE(OFFSET=
=3D$Period),D1*-1,0));

MA(DD1, STYLE=3DExponential, BARS=3D$Pds)*100
